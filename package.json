{
  "name": "preptalk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "api"
  ],
  "scripts": {
    "dev": "npm run dev -w @preptalk/web",
    "dev:web": "npm run dev -w @preptalk/web",
    "dev:api": "npm run dev -w @preptalk/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . 2>/dev/null || true",
    "build": "npm run build -w @preptalk/web && npm run build -w @preptalk/api",
    "build:web": "npm run build -w @preptalk/web",
    "build:api": "tsc -p api/tsconfig.json",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "pdf-parse": "^1.1.1",
    "zod": "4.1.12"
  }
}
