OPENROUTER_API_KEY=
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# OpenRouter chat model (e.g. nvidia/nemotron-3-super-120b-a12b:free, openrouter/owl-alpha)
OPENROUTER_CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b:free


# Voice name configuration (accepts friendly names or Microsoft ShortNames like en-US-AvaNeural / vi-VN-NamMinhNeural)
# Popular English voices: Ava, Andrew, Emma, Brian, Aria, Christopher, Eric, Guy, Jenny, Michelle, Roger, Steffan
VITE_TTS_EN_VOICE_NAME=en-US-AndrewNeural

# Popular Vietnamese voices: HoaiMy, NamMinh
VITE_TTS_VI_VOICE_NAME=vi-VN-NamMinhNeural
