# ── PrepTalk Production Environment ──
# Copy to .env and fill in your values (DO NOT commit .env)

# Server
HOST_PORT=8080
CLIENT_ORIGIN=*

# OpenRouter API
OPENROUTER_API_KEY=***
OPENROUTER_CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# TTS Voices
# English: en-US-AndrewNeural, en-US-AvaNeural, en-US-EmmaNeural, en-US-BrianNeural
# Vietnamese: vi-VN-NamMinhNeural, vi-VN-HoaiMyNeural
VITE_TTS_EN_VOICE_NAME=en-US-AndrewNeural
VITE_TTS_VI_VOICE_NAME=vi-VN-NamMinhNeural

# nport tunnel token (optional)
# NPORT_TOKEN=your-token-here
